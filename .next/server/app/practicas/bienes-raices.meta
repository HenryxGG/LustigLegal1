{
  "headers": {
    "x-nextjs-stale-time": "300",
    "x-nextjs-prerender": "1",
    "x-next-cache-tags": "_N_T_/layout,_N_T_/practicas/layout,_N_T_/practicas/[slug]/layout,_N_T_/practicas/[slug]/page,_N_T_/practicas/bienes-raices"
  },
  "segmentPaths": [
    "/_tree",
    "/_full",
    "/practicas/$d$slug/__PAGE__",
    "/practicas/$d$slug",
    "/practicas",
    "/_index",
    "/_head"
  ]
}